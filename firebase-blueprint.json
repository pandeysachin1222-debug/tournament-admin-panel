{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "walletBalance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Tournament": {
      "title": "Tournament",
      "description": "Tournament details and management",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "game": { "type": "string" },
        "entryFee": { "type": "number" },
        "prizePool": { "type": "number" },
        "maxPlayers": { "type": "number" },
        "commissionRate": { "type": "number" },
        "profit": { "type": "number" },
        "startTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["upcoming", "ongoing", "completed"] },
        "players": { "type": "array", "items": { "type": "string" } },
        "roomId": { "type": "string" },
        "roomPass": { "type": "string" },
        "resultDeclared": { "type": "boolean" }
      },
      "required": ["title", "game", "entryFee", "prizePool", "maxPlayers", "commissionRate", "profit", "startTime", "status"]
    },
    "RechargeRequest": {
      "title": "Recharge Request",
      "description": "User request to add funds",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status", "createdAt"]
    },
    "WithdrawRequest": {
      "title": "Withdraw Request",
      "description": "User request to withdraw funds",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status", "createdAt"]
    },
    "Result": {
      "title": "Result",
      "description": "Tournament results and winners",
      "type": "object",
      "properties": {
        "tournamentId": { "type": "string" },
        "winners": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "rank": { "type": "number" },
              "prize": { "type": "number" }
            }
          }
        },
        "uploadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tournamentId", "winners", "uploadedAt"]
    },
    "AdminEmail": {
      "title": "Admin Email",
      "description": "Authorized admin email addresses",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/admins/{uid}": {
      "schema": "AdminEmail",
      "description": "List of authorized admin UIDs"
    },
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Tournaments"
    },
    "/rechargeRequests/{requestId}": {
      "schema": "RechargeRequest",
      "description": "Recharge requests"
    },
    "/withdrawRequests/{requestId}": {
      "schema": "WithdrawRequest",
      "description": "Withdraw requests"
    },
    "/results/{resultId}": {
      "schema": "Result",
      "description": "Tournament results"
    }
  }
}
